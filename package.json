    "firebase": "^12.11.0",
    "firebase-admin": "^13.7.0",
    "imapflow": "^1.2.18",
    "lucide-react": "^0.546.0",
    "mailparser": "^3.9.6",
    "motion": "^12.23.24",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.4",
    "react": "^19.0.0",
